<mvc:View
    controllerName="com.transferencia.armazens.controller.Transferencia"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page showHeader="false" class="sapUiContentPadding">
        <content>
            <VBox
                alignItems="Center"
                justifyContent="Center"
                height="100%">

                <VBox class="transferCard" alignItems="Center" width="100%">

                    <core:Icon
                        src="sap-icon://accept"
                        size="4rem"
                        color="#16a34a"
                        class="sapUiSmallMarginBottom" />

                    <Title
                        text="Transferência Concluída"
                        level="H2"
                        class="successTitle sapUiSmallMarginBottom" />

                    <Text
                        text="A transferência foi gravada com sucesso no sistema SAP."
                        wrapping="true"
                        textAlign="Center"
                        class="sapUiSmallMarginBottom" />

                    <VBox
                        alignItems="Center"
                        width="100%"
                        class="sapUiMediumMarginTop sapUiMediumMarginBottom">
                        <Label
                            text="NÚMERO DE DOCUMENTO"
                            class="docBadgeLabel" />
                        <VBox class="docBadgeNumber" width="100%">
                            <Text text="{transferView>/documento}" />
                        </VBox>
                    </VBox>

                    <Button
                        text="Fechar e voltar"
                        icon="sap-icon://home"
                        press="onSair"
                        class="btnSair" />

                </VBox>
            </VBox>
        </content>
    </Page>
</mvc:View>