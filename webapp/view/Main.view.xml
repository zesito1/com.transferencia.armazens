<mvc:View
    controllerName="com.cc.tranferencia.armazens.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        title="{i18n>appTitle}"
        class="sapUiContentPadding">

        <content>
            <VBox class="mainContainer">

                <Panel
                    headerText="Centro"
                    class="sapUiResponsiveMargin">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Selecione o centro de origem" />
                        <Select
                            id="selectPlanta"
                            selectedKey="{view>/plantaSelecionada}"
                            width="100%"
                            change=".onPlantaChange" />
                    </VBox>
                </Panel>

                <Panel
                    headerText="Depósito de Destino"
                    class="sapUiResponsiveMargin">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Selecione o depósito de destino" />
                        <Select
                            id="selectDeposito"
                            selectedKey="{view>/depositoSelecionado}"
                            width="100%"
                            change=".onDepositoChange" />
                    </VBox>
                </Panel>

                <Panel
                    headerText="Adicionar SSCC"
                    class="sapUiResponsiveMargin">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Código SSCC (manual ou scanner)" />
                        <Input
                            id="ssccInput"
                            value="{view>/novoSSCC}"
                            placeholder="Ex: 900000290"
                            submit=".onAdicionarSSCC" />
                        <Button
                            text="Adicionar"
                            icon="sap-icon://add"
                            type="Emphasized"
                            press=".onAdicionarSSCC"
                            class="sapUiSmallMarginTop"
                            width="100%" />
                    </VBox>
                </Panel>

                <Panel class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="SSCCs Selecionados" />
                            <ToolbarSpacer />
                            <Text id="ssccCounter" text="0 itens" />
                        </Toolbar>
                    </headerToolbar>
                    <List
                        id="ssccList"
                        items="{view>/ssccs}"
                        noDataText="Nenhum SSCC adicionado ainda."
                        mode="Delete"
                        delete=".onDeleteSSCC">
                        <ObjectListItem
                            title="{view>Exidv}"
                            number="{view>Vemng}"
                            numberUnit="{view>Vemeh}"
                            icon="sap-icon://package">
                            <firstStatus>
                                <ObjectStatus
                                    text="{view>StatusText}"
                                    state="{view>StatusState}"
                                    visible="{= !!${view>StatusText} }" />
                            </firstStatus>
                            <attributes>
                                <ObjectAttribute title="{view>Matnr}" text="{view>Maktx}" />
                                <ObjectAttribute title="Lote" text="{view>Charg}" />
                            </attributes>
                        </ObjectListItem>
                    </List>
                </Panel>

                <Button
                    text="Transferir"
                    icon="sap-icon://save"
                    type="Emphasized"
                    press=".onSave"
                    class="sapUiResponsiveMargin saveButton" />

            </VBox>
        </content>
    </Page>
</mvc:View>
