<mvc:View
    controllerName="com.cc.tranferencia.armazens.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        title="{i18n>appTitle}">

        <content>
            <VBox width="100%" class="mainContent">

                <Panel
                    headerText="Destino"
                    class="sapUiResponsiveMargin">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Centro:" />
                        <Select
                            id="selectPlanta"
                            selectedKey="{view>/plantaSelecionada}"
                            width="100%"
                            change=".onPlantaChange" />
                        <Label
                            text="Depósito Destino:"
                            required="true"
                            class="sapUiSmallMarginTop" />
                        <Select
                            id="selectDeposito"
                            selectedKey="{view>/depositoSelecionado}"
                            width="100%"
                            change=".onDepositoChange" />
                    </VBox>
                </Panel>

                <Panel
                    headerText="SSCC's"
                    class="sapUiResponsiveMargin">
                    <VBox class="sapUiSmallMargin">
                        <Label text="Código SSCC (manual ou scanner)" />
                        <HBox width="100%" alignItems="Center">
                            <Input
                                id="ssccInput"
                                value="{view>/novoSSCC}"
                                placeholder="Ex: 900000290"
                                submit=".onAdicionarSSCC">
                                <layoutData>
                                    <FlexItemData growFactor="1" />
                                </layoutData>
                            </Input>
                            <Button
                                icon="sap-icon://add"
                                type="Emphasized"
                                press=".onAdicionarSSCC" />
                        </HBox>
                    </VBox>
                </Panel>

                <Panel class="sapUiResponsiveMargin">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="SSCCs Selecionados" />
                            <ToolbarSpacer />
                            <Title id="ssccCounter" text="0 itens" level="H4" />
                        </Toolbar>
                    </headerToolbar>
                    <List
                        id="ssccList"
                        items="{view>/ssccs}"
                        noDataText="Nenhum SSCC adicionado ainda."
                        mode="Delete"
                        delete=".onDeleteSSCC">
                        <ObjectListItem
                            title="{view>Exidv}"
                            number="{view>Vemng}"
                            numberUnit="{view>Vemeh}">
                            <firstStatus>
                                <ObjectStatus
                                    text="{view>StatusText}"
                                    state="{view>StatusState}"
                                    visible="{= !!${view>StatusText} }" />
                            </firstStatus>
                            <attributes>
                                <ObjectAttribute title="Material" text="{= ${view>Maktx} + ' (' + ${view>Matnr} + ')' }" />
                                <ObjectAttribute title="Lote" text="{view>Charg}" />
                            </attributes>
                        </ObjectListItem>
                    </List>
                </Panel>

                <Button
                    text="Transferir"
                    icon="sap-icon://save"
                    type="Emphasized"
                    press=".onSave"
                    class="sapUiResponsiveMargin saveButton" />

            </VBox>
        </content>
    </Page>
</mvc:View>
