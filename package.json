{
  "name": "com.cc.transferencia.armazens",
  "version": "0.0.1",
  "description": "App mobile para transferência entre armazéns",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {},
  "devDependencies": {
    "@ui5/cli": "^4.0.33",
    "@sap/ux-ui5-tooling": "1",
    "@sap-ux/deploy-tooling": "^0.19.4",
    "@sap-ux/eslint-plugin-fiori-tools": "^9.0.0",
    "eslint": "^9",
    "rimraf": "^6.0.1"
  },
  "scripts": {
    "start": "fiori run --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "lint": "eslint ./",
    "deploy": "npm run build && fiori deploy --config ui5-deploy.yaml && rimraf archive.zip",
    "deploy-config": "fiori add deploy-config",
    "int-test": "fiori run --open \"test/integration/opaTests.qunit.html\"",
    "unit-test": "fiori run --open \"test/unit/unitTests.qunit.html\""
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
